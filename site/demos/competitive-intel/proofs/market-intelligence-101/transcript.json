      "semantic_score": 0.123,
      "formant_ratio": 0.605,
      "token_count": 29,
      "speaker_turn": false,
      "text": " Generally speaking, companies invest in market intelligence with the intent of mitigating risk, simplifying decision-making, accelerating revenue, and increasing longevity."
    },
