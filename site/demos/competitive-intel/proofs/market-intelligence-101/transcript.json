      "semantic_score": 0.123,
      "formant_ratio": 0.691,
      "token_count": 33,
      "speaker_turn": false,
      "text": " Market intelligence encompasses any and all information that is pertinent to your industry, including your competitors, customers, prospects, partners, suppliers, distributors, and regulators."
    },
